{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaronwriight.vercel.app/schemas/scope-for-imagination-post.json",
  "title": "Scope for Imagination Local Post",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "subtitle", "date", "time", "location", "entry", "tags", "bodyHtml"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "default": "scope for imagination"
    },
    "subtitle": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "time": {
      "type": "string",
      "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
    },
    "location": {
      "type": "string",
      "minLength": 1
    },
    "entry": {
      "type": "string",
      "pattern": "^[0-9]{4}$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "bodyHtml": {
      "type": "string",
      "minLength": 1
    }
  }
}
